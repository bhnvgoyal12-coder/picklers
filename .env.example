VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Razorpay - store both test and live keys, switch with VITE_RAZORPAY_MODE
VITE_RAZORPAY_MODE=test  # test | live
VITE_RAZORPAY_TEST_KEY_ID=rzp_test_xxxxxxxxxxxx
VITE_RAZORPAY_LIVE_KEY_ID=rzp_live_xxxxxxxxxxxx

# Payment flow - direct (Razorpay modal) or whatsapp (payment link via WhatsApp)
VITE_PAYMENT_MODE=direct  # direct | whatsapp
